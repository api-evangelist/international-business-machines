{
  "@context": {
    "@vocab": "https://schema.org/",
    "ibm": "https://cloud.ibm.com/apidocs/",
    "watsonx": "https://cloud.ibm.com/apidocs/watsonx-ai#",
    "assistant": "https://cloud.ibm.com/apidocs/assistant-v2#",
    "nlu": "https://cloud.ibm.com/apidocs/natural-language-understanding#",
    "stt": "https://cloud.ibm.com/apidocs/speech-to-text#",
    "tts": "https://cloud.ibm.com/apidocs/text-to-speech#",
    "cos": "https://cloud.ibm.com/docs/cloud-object-storage#",
    "vpc": "https://cloud.ibm.com/apidocs/vpc/latest#",
    "iks": "https://cloud.ibm.com/apidocs/kubernetes/containers-v1-v2#",
    "FoundationModel": "watsonx:FoundationModel",
    "TextGenerationRequest": "watsonx:TextGenerationRequest",
    "TextGenerationResponse": "watsonx:TextGenerationResponse",
    "Embedding": "watsonx:Embedding",
    "AssistantSession": "assistant:Session",
    "AssistantMessage": "assistant:Message",
    "Intent": "assistant:Intent",
    "Entity": "assistant:Entity",
    "AnalysisResult": "nlu:AnalysisResult",
    "Sentiment": "nlu:Sentiment",
    "Emotion": "nlu:Emotion",
    "Keyword": "nlu:Keyword",
    "Concept": "nlu:Concept",
    "SpeechRecognitionResult": "stt:RecognitionResult",
    "SpeechModel": "stt:SpeechModel",
    "Voice": "tts:Voice",
    "Bucket": "cos:Bucket",
    "StorageObject": "cos:Object",
    "VPC": "vpc:VPC",
    "Instance": "vpc:Instance",
    "Subnet": "vpc:Subnet",
    "SecurityGroup": "vpc:SecurityGroup",
    "Cluster": "iks:Cluster",
    "WorkerNode": "iks:Worker",
    "WorkerPool": "iks:WorkerPool",
    "model_id": "watsonx:model_id",
    "project_id": "watsonx:project_id",
    "assistant_id": "assistant:assistant_id",
    "session_id": "assistant:session_id",
    "transcript": "stt:transcript",
    "confidence": "stt:confidence",
    "crn": "ibm:crn"
  }
}
